# Copy to .env and fill in for production.
# Local dev works with the defaults (SQLite, dev secret) even without this file.

# Postgres example:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/usmlewise
DATABASE_URL=sqlite:///./usmlewise.db

# Generate a strong secret, e.g.:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-please
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
