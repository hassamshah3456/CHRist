<?xml version="1.0" encoding="utf-8"?>
<!-- Disallow cleartext HTTP in release builds (Google Play data-in-transit). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
